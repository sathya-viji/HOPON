# ============================================================================
# HopOn — environment template
# Copy to .env.local for local dev. NEVER commit real values.
# Secrets management strategy (frozen): client-safe values here; server
# secrets live ONLY in Supabase secrets store + GitHub Actions secrets.
# ============================================================================

# ── Client (Expo) — EXPO_PUBLIC_* are bundled into the app; anon key is
#    public by design, RLS is the guard. ─────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=<from `supabase start` output>
EXPO_PUBLIC_POSTHOG_KEY=<posthog project api key>
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
EXPO_PUBLIC_SENTRY_DSN=<sentry dsn>
EXPO_PUBLIC_GOOGLE_PLACES_KEY=<places api key — restrict by bundle id>

# ── CLI / CI only — never in client bundle ──────────────────────────────────
SUPABASE_PROJECT_REF=<prod project ref, e.g. abcdefghijklmnop>
SUPABASE_ACCESS_TOKEN=<personal access token for CLI>
SUPABASE_DB_PASSWORD=<prod database password>

# ── Edge Function secrets — set via `supabase secrets set`, listed here for
#    reference only. DO NOT put real values in any .env file. ────────────────
# SERVICE_ROLE_KEY            — Supabase service role (Edge Functions only)
# GOOGLE_VISION_KEY           — SafeSearch moderation (F2)
# EXPO_ACCESS_TOKEN           — Expo Push API
# TWILIO_ACCOUNT_SID          — emergency-escalation SMS (F4)
# TWILIO_AUTH_TOKEN
# TWILIO_FROM_NUMBER
# FOUNDER_ALERT_PHONE         — emergency pager target (F4)
# EDGE_BASE_URL               — https://<ref>.supabase.co/functions/v1
